# StatMaster Environment Variables

# PostgreSQL (Neon recommended for production)
# Pooled connection for app runtime
DATABASE_URL="postgresql://user:password@localhost:5432/statmaster?schema=public"

# Direct URL for migrations (same as DATABASE_URL for local Postgres; use Neon's direct URL in production)
DIRECT_URL="postgresql://user:password@localhost:5432/statmaster?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"
NEXTAUTH_URL="http://localhost:3000"
