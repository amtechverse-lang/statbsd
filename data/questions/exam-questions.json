    "difficulty": "Hard",
    "type": "ProblemSolving",
    "question": "Two pen refills: joint PMF f(0,0)=3/28, f(1,0)=6/28, f(0,1)=6/28, f(1,1)=2/28 (blue X, red Y). Find Cov(X,Y).",
    "correctAnswer": "-0.1429",
    "hints": [
      "Cov(X,Y)=E(XY)-E(X)E(Y).",
      "E(XY)=Σ xy f(x,y)."
    ],
    "solution": {
      "steps": [
        {
          "step": 1,
          "title": "Means",
          "content": "E(X)=12/28, E(Y)=8/28",
          "explanation": "Marginal expectations."
        },
        {
          "step": 2,
          "title": "E(XY)",
          "content": "E(XY)=1·1·(2/28)=2/28",
          "explanation": "Only (1,1) contributes."
        },
        {
          "step": 3,
          "title": "Covariance",
          "content": "Cov=2/28-(12/28)(8/28)=-16/112≈-0.143",
          "explanation": "Negative correlation: picking blue reduces room for red."
        }
      ],
      "finalAnswer": "≈-0.143",
      "commonMistakes": []
    },
    "tags": [
      "important",
      "exam-style"
    ]
