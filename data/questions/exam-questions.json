          "title": "E(X)",
          "content": "E(X)=0(0.51)+1(0.38)+2(0.10)+3(0.01)=0.63",
          "explanation": "Expected value."
        },
        {
          "step": 2,
          "title": "E(X²)",
          "content": "E(X²)=0+0.38+0.40+0.09=0.87",
