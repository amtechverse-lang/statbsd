  {
    "id": "imp_001",
    "moduleId": "hypergeometric-distribution",
    "topic": "Hypergeometric",
    "subtopic": "Example 3.8",
    "difficulty": "Medium",
    "type": "ProblemSolving",
    "question": "A shipment of 20 laptops contains 3 defectives. A school randomly purchases 2 laptops. Find the probability distribution of X = number of defectives.",
    "correctAnswer": "P(0)=0.7263,P(1)=0.2368,P(2)=0.0368",
    "hints": [
      "Sampling without replacement → hypergeometric.",
      "N=20, K=3 defectives, n=2 sampled.",
      "P(X=x) = C(K,x)C(N-K,n-x)/C(N,n)."
    ],
    "solution": {
      "steps": [
        {
          "step": 1,
          "title": "Identify distribution",
          "content": "X ~ Hypergeometric(N=20, K=3, n=2)",
          "explanation": "No replacement from finite population."
        },
        {
          "step": 2,
          "title": "P(X=0)",
          "content": "C(3,0)C(17,2)/C(20,2) = 136/190 = 0.7158",
          "explanation": "Both laptops are good.",
          "formula": "P(X=0)=\\frac{\\binom{17}{2}}{\\binom{20}{2}}"
        },
        {
          "step": 3,
          "title": "P(X=1)",
          "content": "C(3,1)C(17,1)/C(20,2) = 51/190 = 0.2684",
          "explanation": "One defective, one good."
        },
        {
          "step": 4,
          "title": "P(X=2)",
          "content": "C(3,2)C(17,0)/C(20,2) = 3/190 = 0.0158",
          "explanation": "Both defectives."
        }
      ],
      "finalAnswer": "P(0)≈0.716, P(1)≈0.268, P(2)≈0.016",
      "commonMistakes": [
        "Using binomial with p=3/20 is wrong — sampling is without replacement."
      ]
    },
    "tags": [
      "important",
      "exam-style"
    ]
  },
  {
    "id": "imp_002",
    "moduleId": "continuous-distributions",
    "topic": "Continuous RV",
    "subtopic": "Example 3.11",
    "difficulty": "Medium",
    "type": "ProblemSolving",
    "question": "A continuous RV X has PDF f(x) = x for 0 < x < 2, and 0 elsewhere. (a) Verify f is a density. (b) Find P(0 < X < 1).",
    "correctAnswer": "0.25",
    "hints": [
      "∫f(x)dx over support must equal 1.",
      "P(0<X<1) = ∫₀¹ x dx."
    ],
    "solution": {
      "steps": [
        {
          "step": 1,
          "title": "Verify density",
          "content": "∫₀² x dx = [x²/2]₀² = 2",
          "explanation": "Need f(x)=x/2 on (0,2) for valid PDF; if f(x)=x as stated, ∫=2≠1 — textbook often uses f(x)=x/2. Assuming f(x)=x/2: valid.",
          "formula": "\\int_0^2 f(x)\\,dx = 1"
        },
        {
          "step": 2,
          "title": "Compute probability",
          "content": "P(0<X<1) = ∫₀¹ (x/2) dx = [x²/4]₀¹ = 1/4",
          "explanation": "Integrate PDF over interval."
        }
      ],
      "finalAnswer": "0.25",
      "commonMistakes": [
        "Forgetting to normalize the PDF before integrating."
      ]
    },
    "tags": [
      "important",
      "exam-style"
    ]
  },
  {
    "id": "imp_003",
    "moduleId": "continuous-distributions",
    "topic": "Continuous RV",
    "subtopic": "Exercise 3.7",
    "difficulty": "Medium",
    "type": "ProblemSolving",
    "question": "Vacuum hours X (in units of 100h) has PDF: f(x)=1 for 0<x<1, f(x)=2-x for 1<x<2. Find (a) P(X<1.2) and (b) P(0.5<X<1).",
    "correctAnswer": "0.68,0.5",
    "hints": [
      "Split integral at x=1 where PDF changes.",
      "1.2 in hours = 1.2/100 units? Text uses x in 100h units: <1.2 means x<1.2."
    ],
    "solution": {
      "steps": [
        {
          "step": 1,
          "title": "P(X<1.2)",
          "content": "∫₀¹1 dx + ∫₁^1.2(2-x)dx = 1 + [2x-x²/2]₁^1.2 = 1 + 0.18 = 0.68",
          "explanation": "Piecewise integration."
        },
        {
          "step": 2,
          "title": "P(0.5<X<1)",
          "content": "∫₀.5¹ 1 dx = 0.5",
          "explanation": "Entire interval lies in first piece."
        }
      ],
      "finalAnswer": "P(X<1.2)=0.68, P(0.5<X<1)=0.5",
      "commonMistakes": []
    },
    "tags": [
      "important",
      "exam-style"
    ]
  },
  {
    "id": "imp_004",
    "moduleId": "continuous-distributions",
    "topic": "Continuous RV",
    "subtopic": "Exercise 3.9",
    "difficulty": "Easy",
    "type": "ProblemSolving",
    "question": "Response proportion X has PDF f(x)=3(1-x)² for 0<x<1. (a) Show P(0<X<1)=1. (b) Find P(1/4 < X < 1/2).",
    "correctAnswer": "0.422",
    "hints": [
      "Expand (1-x)² and integrate.",
      "Use substitution u=1-x."
    ],
    "solution": {
      "steps": [
        {
          "step": 1,
          "title": "Normalization",
          "content": "∫₀¹3(1-x)²dx = 3[-(1-x)³/3]₀¹ = 1",
          "explanation": "Valid PDF."
        },
        {
          "step": 2,
          "title": "Interval probability",
          "content": "P(1/4<X<1/2) = [- (1-x)³]_{1/4}^{1/2} = (3/4)³-(1/2)³ = 0.422",
          "explanation": "Antiderivative of 3(1-x)² is -(1-x)³."
        }
      ],
      "finalAnswer": "≈0.422",
      "commonMistakes": []
    },
    "tags": [
      "important",
      "exam-style"
    ]
