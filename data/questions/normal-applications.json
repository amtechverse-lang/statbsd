  {
    "id": "normal_app_019",
    "moduleId": "normal-applications",
    "topic": "Normal Applications",
    "subtopic": "Percentiles",
    "difficulty": "Hard",
    "type": "ProblemSolving",
    "question": "Exam grades: μ=74, σ=7. If 12% get A's (top 12%), what is the lowest A grade?",
    "correctAnswer": "83",
    "hints": [
      "Top 12% means P(Z>z)=0.12",
      "Find z for P(Z<z)=0.88"
    ],
    "tags": [
      "normal",
      "percentile"
    ],
    "solution": {
      "steps": [
        {
          "step": 1,
          "title": "Find z",
          "content": "P(Z<z)=0.88, z≈1.175",
          "explanation": "Use inverse normal."
        },
        {
          "step": 2,
          "title": "Convert",
          "content": "x = 74 + 1.175×7 = 82.22",
          "explanation": "x = μ + zσ"
        },
        {
          "step": 3,
          "title": "Round",
          "content": "Lowest A = 83",
          "explanation": "Round up to whole grade."
        }
      ],
      "finalAnswer": "83",
      "commonMistakes": [
        "Using 0.12 directly",
        "Rounding down"
      ]
    }
  },
